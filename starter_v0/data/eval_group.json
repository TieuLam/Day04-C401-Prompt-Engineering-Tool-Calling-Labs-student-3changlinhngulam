{
  "dataset_id": "day04_group_m2_tools",
  "dataset_role": "group",
  "description": "Group eval cases for M2 added tools: url_cleaner, source_quality, extract_entities, dedupe_sources.",
  "cases": [
    {
      "id": "G01_url_cleaner_tracking_params",
      "phase": "B",
      "suite": "group",
      "query": "Làm sạch link này trước khi đưa vào citation: https://example.com/article?id=123&utm_source=facebook&utm_medium=social&fbclid=abc#comments",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "url_cleaner",
            "args": {
              "url": "https://example.com/article?id=123&utm_source=facebook&utm_medium=social&fbclid=abc#comments"
            }
          }
        ]
      },
      "metadata": {
        "skill": "url_cleaning"
      }
    },
    {
      "id": "G02_url_cleaner_plain_domain",
      "phase": "B",
      "suite": "group",
      "query": "Chuẩn hóa URL này giúp mình trước khi fetch: example.com/news?id=7&utm_campaign=test",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "url_cleaner",
            "args": {
              "url": "example.com/news?id=7&utm_campaign=test"
            }
          }
        ]
      },
      "metadata": {
        "skill": "url_cleaning"
      }
    },
    {
      "id": "G03_source_quality_medical",
      "phase": "B",
      "suite": "group",
      "query": "Đánh giá chất lượng nguồn này cho một claim y tế: https://www.who.int/news-room",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "source_quality",
            "args": {
              "url": "https://www.who.int/news-room",
              "claim_type": "medical"
            }
          }
        ]
      },
      "metadata": {
        "skill": "source_quality"
      }
    },
    {
      "id": "G04_source_quality_shortlink",
      "phase": "B",
      "suite": "group",
      "query": "Nguồn bit.ly/ai-report này có đáng tin để dùng trong report không?",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "source_quality",
            "args": {
              "url": "bit.ly/ai-report"
            }
          }
        ]
      },
      "metadata": {
        "skill": "source_quality"
      }
    },
    {
      "id": "G05_extract_entities_text",
      "phase": "B",
      "suite": "group",
      "query": "Trích xuất entity trong đoạn này: VinUni announced the AI program on 28/05/2026. Contact ai@vinuni.edu.vn or visit https://vinuni.edu.vn. Tuition is 100 USD.",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "extract_entities",
            "args": {
              "text": "VinUni announced the AI program on 28/05/2026. Contact ai@vinuni.edu.vn or visit https://vinuni.edu.vn. Tuition is 100 USD."
            }
          }
        ]
      },
      "metadata": {
        "skill": "entity_extraction"
      }
    },
    {
      "id": "G06_extract_entities_max_items",
      "phase": "B",
      "suite": "group",
      "query": "Lấy tối đa 5 entity mỗi loại từ đoạn sau: Email support@example.com, ngày 2026-06-02, link https://example.com, hashtag #AI.",
      "failure_type": "wrong_arg_value",
      "expect": {
        "tool_calls": [
          {
            "name": "extract_entities",
            "args": {
              "max_items": 5
            }
          }
        ]
      },
      "metadata": {
        "skill": "entity_extraction"
      }
    },
    {
      "id": "G07_dedupe_sources_by_url",
      "phase": "B",
      "suite": "group",
      "query": "Loại trùng danh sách nguồn sau theo URL: [{\"title\":\"AI news\",\"url\":\"https://example.com/a?utm_source=x\"}, {\"title\":\"AI news\",\"url\":\"https://example.com/a\"}, {\"title\":\"Other report\",\"url\":\"https://another.com/report\"}]",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
            "name": "dedupe_sources",
            "args": {
              "unique_by": "url"
            }
          }
        ]
      },
      "metadata": {
        "skill": "source_deduplication"
      }
    },
    {
      "id": "G08_dedupe_sources_by_domain",
      "phase": "B",
      "suite": "group",
      "query": "Trong danh sách nguồn này, chỉ giữ một nguồn mỗi domain: [{\"title\":\"Report 1\",\"url\":\"https://example.com/a\"}, {\"title\":\"Report 2\",\"url\":\"https://example.com/b\"}, {\"title\":\"Report 3\",\"url\":\"https://openai.com/news\"}]",
      "failure_type": "wrong_arg_value",
      "expect": {
        "tool_calls": [
          {
            "name": "dedupe_sources",
            "args": {
              "unique_by": "domain"
            }
          }
        ]
      },
      "metadata": {
        "skill": "source_deduplication"
      }
    }
  ]
}